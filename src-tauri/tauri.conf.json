{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Tools",
  "version": "1.0.0",
  "identifier": "io.github.micaelvinhas.pdftools",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PDF Tools",
        "width": 780,
        "height": 620,
        "minWidth": 540,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": {
      "../sidecar/pdf_worker.py": "sidecar/pdf_worker.py"
    }
  }
}
